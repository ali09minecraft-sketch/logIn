<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<title>تسجيل الدخول</title>
<%- include('partials/head') %>
</head>
<body>

<div class="topbar">
  <a href="/" class="brand">auth<span>.app</span></a>
  <div class="topbar-links">
    <a href="/register" class="accent">إنشاء حساب جديد</a>
  </div>
</div>

<div class="auth-wrap">
  <div class="auth-card">
    <span class="auth-eyebrow">مرحبًا بعودتك</span>
    <h1>تسجيل الدخول</h1>
    <p class="auth-sub">أدخلي بياناتك للوصول إلى حسابك.</p>

    <% if (error) { %>
      <div class="alert"><%= error %></div>
    <% } %>

    <form method="POST" action="/login" id="loginForm" novalidate>
      <input type="hidden" name="next" value="<%= next %>">

      <div class="field">
        <label for="email">البريد الإلكتروني</label>
        <input type="email" id="email" name="email" placeholder="you@example.com" value="<%= old.email || '' %>" required autocomplete="email" autofocus>
      </div>

      <div class="field">
        <label for="password">كلمة المرور</label>
        <div class="pw-wrap">
          <input type="password" id="password" name="password" placeholder="كلمة المرور" required autocomplete="current-password">
          <button type="button" class="pw-toggle" data-target="password">إظهار</button>
        </div>
      </div>

      <button type="submit" class="btn-submit" id="submitBtn">تسجيل الدخول</button>
    </form>

    <div class="auth-footer-note">
      لا تملكين حسابًا؟ <a href="/register">أنشئي حسابًا جديدًا</a>
    </div>
  </div>
</div>

<script>
document.querySelectorAll('.pw-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const input = document.getElementById(btn.dataset.target);
    const showing = input.type === 'text';
    input.type = showing ? 'password' : 'text';
    btn.textContent = showing ? 'إظهار' : 'إخفاء';
  });
});

document.getElementById('loginForm').addEventListener('submit', () => {
  const btn = document.getElementById('submitBtn');
  btn.disabled = true;
  btn.textContent = 'جاري تسجيل الدخول…';
});
</script>

</body>
</html>
